            "/api/v1/subdireccions",
            headers=headers,
            json={"nombre": f"Sub {x}", "codigo": f"SUB-{x}", "descripcion": "t"},
        )
        assert sub.status_code == 201, sub.text
        sub_id = sub.json()["data"]["id"]
