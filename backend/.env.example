# ==============================================================================
# AppSec Platform — variables de ejemplo (backend aislado)
# ==============================================================================
# Despliegue con Docker Compose (recomendado en Ubuntu): usa el fichero **/.env**
# en la **raíz del repositorio** (plantilla: `/.env.example` en el repo). Allí están
# SECRET_KEY, APPSEC_MASTER_KEY, CORS, Celery, OLLAMA_*, etc. que inyecta Compose.
#
# Copia local solo del backend:  cp .env.example .env  (desde este directorio)
# ==============================================================================

# ==============================================================================
# DATABASE
# ==============================================================================
DATABASE_URL=postgresql://appsec:appsec_password@postgres:5432/appsec_db
DATABASE_ECHO=false  # Set to true for SQL debugging

# ==============================================================================
# JWT & AUTHENTICATION
# ==============================================================================
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==============================================================================
# REDIS (Cache & Queue)
# ==============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600

# ==============================================================================
# CELERY (Async Task Queue)
# ==============================================================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_TIME_LIMIT=1800  # 30 minutes

# ==============================================================================
# LOGGING
# ==============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or text

# ==============================================================================
# CODE SECURITY REVIEWS (SCR)
# ==============================================================================

# --- LLM Configuration ---
SCR_LLM_PROVIDER=anthropic  # anthropic, openai, ollama, openrouter, litellm, etc
SCR_LLM_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI GPT
OPENAI_API_KEY=sk-proj-xxxxx

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama2

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-xxxxx
OPENROUTER_MODEL=anthropic/claude-3-5-sonnet

# LiteLLM Proxy
LITELLM_BASE_URL=http://litellm:4000

# Nvidia NIM
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_API_KEY=nvapi-xxxxx

# Google Gemini
GOOGLE_API_KEY=xxxxx

# LM Studio (Local)
LM_STUDIO_BASE_URL=http://localhost:1234/v1

# --- Code Analysis ---
SCR_MAX_CHUNK_BYTES=200000  # Max code bytes per LLM request
SCR_ANALYSIS_TIMEOUT_MINUTES=30
SCR_TEMP_DIR=/tmp/scr_analysis  # Temp directory for code downloads

# --- GitHub Integration ---
GITHUB_OAUTH_CLIENT_ID=Iv1.xxxxx
GITHUB_OAUTH_CLIENT_SECRET=xxxxx
GITHUB_OAUTH_REDIRECT_URL=http://localhost:3000/callback/github
GITHUB_API_TOKEN=ghp_xxxxx  # Personal access token for API calls

# --- GitLab Integration (Optional) ---
GITLAB_OAUTH_CLIENT_ID=xxxxx
GITLAB_OAUTH_CLIENT_SECRET=xxxxx
GITLAB_OAUTH_REDIRECT_URL=http://localhost:3000/callback/gitlab
GITLAB_API_TOKEN=glpat-xxxxx

# --- Webhooks ---
SCR_WEBHOOK_TIMEOUT_SECONDS=300
SCR_WEBHOOK_MAX_RETRIES=3
SCR_WEBHOOK_VERIFY_SSL=true

# ==============================================================================
# CORS & SECURITY
# ==============================================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET","POST","PUT","PATCH","DELETE"]

# ==============================================================================
# FRONTEND
# ==============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_ENVIRONMENT=development

# ==============================================================================
# MONITORING & ANALYTICS (Optional)
# ==============================================================================
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
ENABLE_SENTRY=false

# DataDog
DATADOG_API_KEY=xxxxx
ENABLE_DATADOG=false

# ==============================================================================
# DEVELOPMENT
# ==============================================================================
DEBUG=true
ENVIRONMENT=development  # development, staging, production

# ==============================================================================
# RATE LIMITING
# ==============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ==============================================================================
# MAIL (Optional - for notifications)
# ==============================================================================
MAIL_FROM=noreply@appsec-platform.local
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=your-email@gmail.com
MAIL_SMTP_PASSWORD=your-app-password
MAIL_SMTP_TLS=true

# ==============================================================================
# END OF ENVIRONMENT VARIABLES
# ==============================================================================
