# ──────────────────────────────────────────────────────────────────────
# Framework Environment Variables
#
# Docker Compose **solo carga el fichero `.env` de esta raíz**, no este fichero.
# Tras clonar:  `cp .env.example .env`  (las líneas de abajo incluyen secretos de
# **solo desarrollo local** para que `make up` arranque; cámbialos en staging/prod).
# ──────────────────────────────────────────────────────────────────────

# ─── Environment ─────────────────────────────────────────────────────
# Controls the `secure` flag on auth cookies (true only when prod).
# Allowed: dev | staging | prod
ENV=dev

# ─── Required Secrets (MUST be set) ──────────────────────────────────

# JWT signing (min 32 chars). Solo local — genera otro para entornos reales:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=frmwk_localdev_secret_key_not_for_production_2026!

# Cifrado at-rest (A5). Debe ser una clave Fernet (no contraseña arbitraria).
# Solo local — misma clave que CI de ejemplo; en prod genera una nueva:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APPSEC_MASTER_KEY=bOEizITi-HIjCc8gIlF3FMfwidr6I0z7RFGXJdfizwU=

# Initial admin credentials (used by seed script)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Changeme123!

# ─── Database ────────────────────────────────────────────────────────

# For Docker Compose (default):
DATABASE_URL=postgresql+asyncpg://framework:framework_secret@postgres:5432/framework

# If running locally:
# DATABASE_URL=postgresql+asyncpg://framework:framework_secret@localhost:5432/framework

POSTGRES_USER=framework
POSTGRES_PASSWORD=framework_secret
POSTGRES_DB=framework

# ─── Redis / Cache ───────────────────────────────────────────────────
# Leave empty to use in-memory fallback
REDIS_URL=redis://redis:6379/0
# Puerto en el **host** para mapear Redis (redis-cli, depuración). 16379 por defecto en
# docker-compose para no chocar con un Redis del sistema en :6379. Cambia a 6379 si liberas el puerto.
REDIS_PUBLISH_PORT=16379
DASHBOARD_CACHE_TTL_SECONDS=120

# ─── JWT & Auth ──────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7
AUTH_MIN_PASSWORD_LENGTH=10
AUTH_LOGIN_RATE_LIMIT_PER_MIN=10
AUTH_REGISTER_RATE_LIMIT_PER_MIN=5
AUTH_REFRESH_RATE_LIMIT_PER_MIN=30
AUTH_LOCKOUT_THRESHOLD=5
AUTH_LOCKOUT_MINUTES=15
AUTH_COOKIE_SAMESITE=lax
AUTH_PASSWORD_REQUIRE_MIXED_CASE=true
AUTH_PASSWORD_REQUIRE_DIGIT=true
AUTH_PASSWORD_REQUIRE_SYMBOL=false

# ─── CORS ────────────────────────────────────────────────────────────
# Local: orígenes HTTP habituales. En servidor Ubuntu con DNS público y HTTPS,
# añade https://tu-dominio (debe coincidir con el map de nginx/nginx.conf).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost

# ─── Frontend (Next.js build-time) ────────────────────────────────────
# Vacío = mismo origen que la página (detrás de Nginx en :80). Recomendado en prod.
# Solo pon URL absoluta si el navegador llama directo al backend (ej. dev en :8000).
NEXT_PUBLIC_API_URL=

# ─── Redis / Celery (Compose inyecta estas si existen) ────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ─── SSE ──────────────────────────────────────────────────────────────
SSE_ENABLED=true
SSE_KEEPALIVE_INTERVAL=30

# ─── Logging / Observability ─────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_SAMPLE_HEALTH=0.0
SENTRY_DSN=

# ─── Email Notifications (S18) ───────────────────────────────────────
EMAIL_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=notifications@appsec.local
SMTP_FROM_NAME="AppSec Platform"
SMTP_USE_TLS=true
SCHEDULE_EMAIL_WORKER=false

# ─── Notification Rules (G2) ─────────────────────────────────────────
SCHEDULE_NOTIFICATION_RULES=false
NOTIFICATION_CRON_HOUR_UTC=2

# ─── Integrations (Optional) ─────────────────────────────────────────

# SCR (Code Security Review) dedicated token
SCR_GITHUB_TOKEN=

# Argus / MCP
ARGUS_URL=http://localhost:8899
ARGUS_API_KEY=
ARGUS_CONNECTION_TYPE=http

# ─── AI Provider ─────────────────────────────────────────────────────
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4o
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
# URL del API Ollama visto DESDE el contenedor backend. En Docker Desktop ya existe
# host.docker.internal; en Ubuntu Linux Compose añade extra_hosts (ver docker-compose.yml).
# Si Ollama corre en otro host/puerto, ajusta aquí y usa la MISMA en OLLAMA_BASE_URL.
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ─── Seed & Docs ─────────────────────────────────────────────────────
# RUN_SEED: el entrypoint de Compose solo ejecuta `python -m app.seed` si el valor
#   es exactamente la cadena `true` (comparación en shell dentro de docker-compose.yml).
#   Riesgo corregido: `RUN_SEED:-false` en compose → sin clave en .env el seed NO corre;
#   copia este archivo a .env o define RUN_SEED=true a mano.
# Nuevas variables para el contenedor backend: 1) añade aquí y en `docker-compose.yml`
#   bajo `services.backend.environment`, 2) si las lee Pydantic, decláralas en
#   `backend/app/config.py` (Settings), 3) secretos: nunca valores reales en el repo.
# Código del seed sin verse reflejado: la imagen oficial puede no montar `./backend`;
#   entonces `docker compose build backend` (ver README / AGENTS.md).
# SEED_DEMO_BUSINESS: true = dataset [DEMO] completo (vulns con prefijo [DEMO], OKR, auditorías…).
#   false (recomendado) = solo bootstrap: catálogos, KPIs, inventario SEED-* y programas/pipeline operativos.
SEED_DEMO_BUSINESS=false
RUN_SEED=true
ENABLE_OPENAPI_DOCS=true
ALLOW_OPENAPI_IN_PROD=false
MAX_UPLOAD_SIZE_MB=10
