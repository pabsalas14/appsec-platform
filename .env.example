# ──────────────────────────────────────────────────────────────────────
# Framework Environment Variables
# Copy to .env and fill in the values before running `make up`.
# ──────────────────────────────────────────────────────────────────────

# ─── Environment ─────────────────────────────────────────────────────
# Controls the `secure` flag on auth cookies (true only when prod).
# Allowed: dev | staging | prod
ENV=dev

# ─── Required (no defaults — MUST be set) ────────────────────────────

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Initial admin credentials (used by seed script)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Changeme123!

# ─── Database ────────────────────────────────────────────────────────

POSTGRES_USER=framework
POSTGRES_PASSWORD=framework_secret
POSTGRES_DB=framework

# Constructed from the above — usually no need to change
# DATABASE_URL=postgresql+asyncpg://framework:framework_secret@postgres:5432/framework

# ─── JWT ─────────────────────────────────────────────────────────────

JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7
AUTH_MIN_PASSWORD_LENGTH=10
AUTH_LOGIN_RATE_LIMIT_PER_MIN=10
AUTH_REGISTER_RATE_LIMIT_PER_MIN=5
AUTH_REFRESH_RATE_LIMIT_PER_MIN=30
AUTH_LOCKOUT_THRESHOLD=5
AUTH_LOCKOUT_MINUTES=15

# Cookie policy (ADR-0015). 'none' is only accepted when ENV=prod so cookies
# are also Secure. Use 'strict' to deny all cross-site POSTs even with SameSite.
AUTH_COOKIE_SAMESITE=lax

# Password policy (ADR-0015). Mixed-case + digit are on by default.
AUTH_PASSWORD_REQUIRE_MIXED_CASE=true
AUTH_PASSWORD_REQUIRE_DIGIT=true
AUTH_PASSWORD_REQUIRE_SYMBOL=false

# ─── CORS ────────────────────────────────────────────────────────────

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost

# ─── Frontend ────────────────────────────────────────────────────────

# Leave empty when running behind nginx (default).
# Set to http://localhost:8000 for direct backend access during frontend dev.
NEXT_PUBLIC_API_URL=

# ─── Seed ────────────────────────────────────────────────────────────

RUN_SEED=false

# ─── Webhook / SLA (optional) ───────────────────────────────────────

WEBHOOK_URL=
WEBHOOK_TYPE=slack
SLA_ALERT_DAYS=5

# ─── SSE (Server-Sent Events) ───────────────────────────────────────

SSE_ENABLED=true
SSE_KEEPALIVE_INTERVAL=30

# ─── OpenAPI Docs ────────────────────────────────────────────────────
# In production, docs stay disabled unless ALLOW_OPENAPI_IN_PROD=true is also set.
ENABLE_OPENAPI_DOCS=true
ALLOW_OPENAPI_IN_PROD=false

# ─── Upload limits ──────────────────────────────────────────────────

MAX_UPLOAD_SIZE_MB=10

# ─── MCP / Argus integration (optional) ─────────────────────────────

ARGUS_URL=http://localhost:8899
ARGUS_API_KEY=
ARGUS_CONNECTION_TYPE=http

# ─── AI Provider (optional) ─────────────────────────────────────────

AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4o
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_URL=http://localhost:11434
