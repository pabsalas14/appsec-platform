{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/app/**/{page,layout,loading,error,not-found,route,template,default}.{ts,tsx}",
    "src/middleware.ts",
    "src/app/**/{opengraph,twitter}-image.{ts,tsx}",
    "next.config.{js,ts}",
    "tailwind.config.{js,ts}",
    "postcss.config.{js,ts}",
    "vitest.config.ts",
    "vitest.setup.ts",
    "playwright.config.ts",
    "src/__tests__/**/*.{ts,tsx}",
    "e2e/**/*.ts"
  ],
  "project": ["src/**/*.{ts,tsx}", "e2e/**/*.ts"],
  "ignoreDependencies": [
    "autoprefixer",
    "postcss",
    "tailwindcss",
    "tailwindcss-animate",
    "eslint-config-next",
    "@types/node",
    "@types/react",
    "@types/react-dom"
  ],
  "ignore": ["src/types/api.ts"]
}
